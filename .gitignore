# Environment files with secrets
.env
*.env

# Droplet configuration (contains credentials)
droplet_config.json

# Python
__pycache__/
*.py[cod]
venv/
.venv/

# Cursor (except automations governance suite and shared agent rules)
.cursor/
!.cursor/automations/
!.cursor/automations/**
!.cursor/rules/
!.cursor/rules/**

# Logs (runtime; symlink may point to persistent volume — see scripts/ops/mount_alpaca_telemetry_to_volume.sh)
*.log

# State files
state/
logs/
feature_store/
*.jsonl
!reports/stockbot/**/*.jsonl

# UW cache corruption artifacts
data/uw_flow_cache.json.corrupted*.json

# Telemetry milestone watcher dedupe state (droplet/local)
data/.milestone_state.json

# Exports (runtime artifacts)
exports/

# Telemetry computed/generated (keep structure, ignore date dirs)
telemetry/20*/

# Droplet sync artifacts (pulled locally for review)
droplet_sync/

# Post-close analysis packs (runtime artifacts)
analysis_packs/

# IDE
.vscode/
.idea/
# Trigger investigation
# OS junk
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.lock

# Backup files
*.bak
*.backup

# Model/cache artifacts
*.pkl

# Backtest run outputs (regeneratable)
backtests/30d_*/
reports/backtests/

# Local Alpaca strict replay lab snapshots (copied jsonl; regeneratable)
artifacts/alpaca_replay_lab_smoke/

# Bars / droplet run artifacts
reports/bars/
reports/bars_droplet_*/

# Fetched bar data (regeneratable; keep off git — use volume + symlink for durability)
data/bars/
data/bars_cache/

# Timestamped Cursor/board run outputs (regeneratable)
reports/*/*_202*Z/
