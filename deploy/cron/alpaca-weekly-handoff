# Alpaca Wednesday handoff — Mon–Wed ET summary + decile Markdown + Cursor prompt → Telegram.
# Install: sudo cp deploy/cron/alpaca-weekly-handoff /etc/cron.d/alpaca-weekly-handoff
#          sudo chmod 644 /etc/cron.d/alpaca-weekly-handoff
# Log: /var/log/alpaca_handoff.log (create if missing: sudo touch /var/log/alpaca_handoff.log && sudo chown root:root)
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
CRON_TZ=America/New_York
15 20 * * 3 root /root/stock-bot/venv/bin/python3 /root/stock-bot/scripts/analysis/alpaca_weekly_handoff.py >> /var/log/alpaca_handoff.log 2>&1
