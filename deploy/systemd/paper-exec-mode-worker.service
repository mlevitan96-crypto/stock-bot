[Unit]
Description=Process paper_exec_pending (PASSIVE_THEN_CROSS worker; paper gateway enforced in script)
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/stock-bot-v3
EnvironmentFile=-/root/stock-bot-v3/.env
ExecStart=/usr/bin/python3 /root/stock-bot-v3/scripts/paper_exec_mode_worker.py --root /root/stock-bot-v3 --once
User=root

[Install]
WantedBy=multi-user.target
