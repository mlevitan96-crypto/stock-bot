[Unit]
Description=Alpaca Shadow ML milestone watcher (ml_expected_eod_return Telegram)
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/stock-bot-v3
EnvironmentFile=-/root/stock-bot-v3/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/root/stock-bot-v3/venv/bin/python /root/stock-bot-v3/scripts/audit/alpaca_shadow_ml_milestone_watcher.py
