# Copy to .env and fill in. .env is gitignored.
# Get a token: https://github.com/settings/tokens (scope: repo)
GITHUB_TOKEN=

# --- Paper trading: get real trades (see reports/audit/REAL_TRADES_BOARD_VERDICT.md) ---
# When UW root-cause data is missing, passthrough preserves composite score so clusters can reach execution.
# UW_MISSING_INPUT_MODE=passthrough
# Inject test: only set to 1 for execution-path testing; leave unset or 0 for normal trading.
# INJECT_SIGNAL_TEST=0
