{
  "scope": "all_sessions_all_symbols",
  "mode": "paper_only",
  "feature": "B2_no_early_signal_decay_exit",
  "duration": {
    "min_evaluation_days": 7,
    "min_sample_size_exits": 50
  },
  "primary_metrics": [
    "delta_realized_pnl_attribution_vs_baseline",
    "delta_drawdown_worst_tail",
    "delta_exit_reason_mix_signal_decay_share_drop"
  ],
  "tripwires": [
    {
      "id": "paper_safety_violation",
      "condition": "count > 0",
      "action": "immediate_rollback"
    },
    {
      "id": "tail_risk_breach",
      "condition": "worst_5pct_pnl worse than baseline worst 5% by > 20% relative",
      "action": "rollback"
    },
    {
      "id": "sustained_negative_delta",
      "condition": "realized_expectancy below baseline by > 15% for 3+ consecutive days",
      "action": "rollback"
    }
  ],
  "rollback": {
    "steps": [
      "Set FEATURE_B2_NO_EARLY_SIGNAL_DECAY_EXIT=false (or unset) on droplet .env",
      "sudo systemctl restart stock-bot",
      "Verify health endpoints 200 and flag OFF"
    ],
    "one_liner": "sed -i 's/FEATURE_B2_NO_EARLY_SIGNAL_DECAY_EXIT=true/FEATURE_B2_NO_EARLY_SIGNAL_DECAY_EXIT=false/' /root/stock-bot/.env && sudo systemctl restart stock-bot"
  }
}
